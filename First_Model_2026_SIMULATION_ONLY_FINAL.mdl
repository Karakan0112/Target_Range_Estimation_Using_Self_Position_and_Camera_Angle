__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_62.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="62">
  <P Name="name">RLS_algorithm/RLS_Dynamic</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">62</P>
  <P Name="ssIdHighWaterMark">9</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">5</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">RLS_Dynamic</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">62</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [est_x, est_y, exec_time] = RLS_Dynamic(x_i, y_i, beta_i) 
% RLS_Dynamic_Final
% Performs Recursive Least Squares (RLS) tracking for a moving target.
% Inputs:
%
%   x_i, y_i : Our Ship&apos;s Position (Self)
%   beta_i   : Noisy Angle Measurement (Radians)
% Outputs:
%   est_x, est_y : Estimated Target Position

% --- Persistent Memory ---
persistent P X_i lambda lambda_rate

% --- Timing Setup ---
exec_time = 0; 
coder.extrinsic(&apos;tic&apos;, &apos;toc&apos;); 
tStart = tic; 

% --- Initialization (Runs once at t=0) ---
if isempty(P)
    % We set P to 10000 so the filter isn&apos;t &quot;stubborn&quot; at the start.
    % It allows the estimate to snap to the true position in short time.
    P = 10000 * eye(2);  
    
    % FIX 2: Tuned Forgetting Factor (Lambda)
    % We start with a lower lambda to learn quickly, then slowly increase it.
    lambda = 0.95; 
    
    % The &apos;Rate&apos; controls how fast it hardens. 
    lambda_rate = 0.8; 
end

if isempty(X_i)
    X_i = zeros(2, 1);  % X vector initialization as a zero vector
end

% --- 1. Construct Pseudolinear Measurement ---
% Measurement Vector (phi) and Scalar (z)
% Model: -x*sin(beta) + y*cos(beta) = y_obs*cos(beta) - x_obs*sin(beta)
phi_i = [-sin(beta_i); cos(beta_i)];
z_i   = y_i * cos(beta_i) - x_i * sin(beta_i);

% --- 2. Calculate RLS Updates ---

% A. Estimation Error
e = z_i - phi_i&apos; * X_i;

% B. Calculate Gain Vector (g_k)
% We use 3e-5 for R (Noise Variance) to scale the denominator correctly.
R_cov = 3e-5; 
denominator = (lambda * R_cov) + (phi_i&apos; * P * phi_i);
g_k = (P * phi_i) / denominator;

% C. Update State Vector (Position Estimate)
X_i = X_i + g_k * e;

% D. Update Covariance Matrix (P)
P = (1 / lambda) * (P - g_k * phi_i&apos; * P);

% Prevents numerical crashes over long simulations.
P = 0.5 * (P + P&apos;);

% --- 3. Update Lambda (Annealing with Safety Cap) ---
% Slowly increase lambda to smooth out the noise...
lambda = lambda_rate * lambda + (1 - lambda_rate);

if lambda &gt; 0.9999999
    lambda = 0.9999999;
end

% --- Outputs ---
est_x = X_i(1);
est_y = X_i(2);
exec_time = toc(tStart); 
end</P>
      </eml>
    </state>
    <data SSID="6" name="x_i">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="y_i">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="beta_i">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="est_x">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="est_y">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="9" name="exec_time">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <transition SSID="2">
      <P Name="labelString">{eML_blk_kernel();}</P>
      <P Name="labelPosition">[28.125 13.875 102.544 14.964]</P>
      <P Name="fontSize">12</P>
      <src>
        <P Name="intersection">[0 0 1 0 23.5747 14.625 0 0]</P>
      </src>
      <dst>
        <P Name="SSID">3</P>
        <P Name="intersection">[1 0 -1 0 23.5747 42.5747 0 0]</P>
      </dst>
      <P Name="midPoint">[23.5747 24.9468]</P>
      <P Name="dataLimits">[21.175 25.975 14.625 42.575]</P>
      <P Name="subviewer">62</P>
      <P Name="drawStyle">SMART</P>
      <slide>
        <P Name="sticky">BOTH_STICK</P>
      </slide>
      <P Name="executionOrder">1</P>
    </transition>
    <junction SSID="3">
      <P Name="position">[23.5747 49.5747 7]</P>
