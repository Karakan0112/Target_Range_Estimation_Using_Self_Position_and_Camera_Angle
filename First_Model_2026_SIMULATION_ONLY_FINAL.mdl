<?xml version="1.0" encoding="utf-8"?>
<chart id="16">
  <P Name="name">Observer_Position/Circular_transformation</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">16</P>
  <P Name="visible">1</P>
  <subviewS/>
  <P Name="ssIdHighWaterMark">11</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">1</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">Kinematics_Circular</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">16</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [x_circular, y_circular] = Kinematics_Circular(x_init, y_init, w, t)
    % Kinematics_Circular Calculates self position for constant angular velocity motion.
    % This path is crucial for ensuring observability in passive tracking problems.
    %
    % Inputs: 
    %   x_init, y_init: Initial position (meters). This defines the center offset.
    %   t: Current simulation time (seconds).
    %   w: Angular velocity (rad/s).
    
    % --- 1. Calculate Radius ---
    % The radius (R) of the circular path is determined by the distance 
    % from the origin (0,0) to the initial position (x_init, y_init).
    R = sqrt(x_init^2 + y_init^2);
    
    % Safety check: If starting at (0,0), set a minimum radius to avoid zero movement.
    if R == 0
        R = 100; % Default to a 100m radius if the initial position is the origin.
    end
    
    % --- 2. Calculate Circular Motion (ENU Coordinates) ---
    % The motion is centered around the origin, but since R is derived from 
    % x_init and y_init, this effectively creates a circle that passes 
    % through the start point, relative to the origin.
    % Based on the report&apos;s kinematic equation (Eq 56 &amp; 57):
    % x = R*cos(w*t) + x0
    % y = R*sin(w*t) + y0 (Note: The report uses y0 as an offset, but R already accounts for it.)
    
    % To ensure the circle is centered around a specific offset (e.g., [x_init, y_init] if R was calculated differently),
    % you would add the offset here. Given the report&apos;s equations (56, 57), 
    % we will assume the circular path is centered around the origin, as R already uses the initial position.
    % If the intent is for the circle to be centered at [x_init, y_init]:
    % x_circular = R * cos(w * t) + x_init;
    % y_circular = R * sin(w * t) + y_init;
    % I will use the standard circular motion relative to the origin as defined by R:
    
    % We apply a translational offset to center the circular path 
    % such that the initial position (x_init, y_init) defines the circle&apos;s origin (center) relative to its radius.
    % This matches the structure of equations 56 &amp; 57 from the reference report&apos;s block modeling (which assumes center offset).
    x_circular = R * cos(w * t) + x_init;
    y_circular = R * sin(w * t) + y_init;
</P>
      </eml>
    </state>
    <data SSID="4" name="x_init">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="y_init">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="w">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="10" name="t">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="x_circular">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
