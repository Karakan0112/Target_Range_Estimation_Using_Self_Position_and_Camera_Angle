<?xml version="1.0" encoding="utf-8"?>
<chart id="129">
  <P Name="name">EKF_algorithm/EKF_Dynamic</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">129</P>
  <P Name="ssIdHighWaterMark">10</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">11</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">EKF_Dynamic</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">129</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [est_x, est_y, exec_time] = EKF_Dynamic(x_i, y_i, beta_i)
    % EKF_Dynamic_StudentVersion (8-State)
    % Jointly estimates Target State (Pos+Vel) and Self State (Pos+Vel).

    
    persistent X_est P Q R
    
    % --- Timing ---
    exec_time = 0; 
    coder.extrinsic(&apos;tic&apos;, &apos;toc&apos;); 
    tStart = tic;

    % --- Initialization ---
    if isempty(P)
        % 1. Covariance (P)
        % Start high (1000) so the filter doesn&apos;t stick to zero initially.
        % 1000 ensures faster convergence.
        P = 1000 * eye(8); 
        
        % 2. Process Noise (Q) - 8x8 Matrix

        Q = 0.1 * diag([0.01, 0.00001, 0.01, 0.00001, 10, 0.001, 10, 1]);
        
        % 3. Measurement Noise (R) - 3x3 Matrix
        % [Var_Self_X, Var_Self_Y, Var_Constraint]
        % UPDATED based on your Simulink values:
        % - Self Position Noise = 5
        % - Constraint Noise = 1000 (Student value, kept as tuning parameter)
        R = diag([5, 5, 1000]); 
    end
    
    if isempty(X_est)
        X_est = zeros(8, 1); % [x_t; vx_t; y_t; vy_t; x_s; vx_s; y_s; vy_s]
    end

    % --- Constants ---
    dt = 0.01; % Sample Time 

    % --- 1. PREDICT STEP (Process Model) ---
    % Constant Velocity Model for ALL 8 states.
    % F matrix propagates position: x = x + vx*dt
    
    F = [1 dt 0  0  0  0  0  0;  % Target X
         0  1 0  0  0  0  0  0;  % Target Vx
         0  0 1 dt  0  0  0  0;  % Target Y
         0  0 0  1  0  0  0  0;  % Target Vy
         0  0 0  0  1 dt  0  0;  % Self X
         0  0 0  0  0  1  0  0;  % Self Vx
         0  0 0  0  0  0  1 dt;  % Self Y
         0  0 0  0  0  0  0  1]; % Self Vy
         
    % Predict State
    X_est = F * X_est;
    
    % Predict Covariance
    P = F * P * F&apos; + Q;

    % --- 2. UPDATE STEP (Measurement) ---
    
    % Measurement Matrix (H) - 3x8
    % Rows 1-2: Measure Self Position (States 5 and 7)
    % Row 3: Pseudolinear Constraint: 0 = x_t*sin - y_t*cos - x_s*sin + y_s*cos
    
    sin_b = sin(beta_i);
    cos_b = cos(beta_i);
    
    % Note indices carefully:
    % Target X (1), Target Y (3) -&gt; In constraint
    % Self X (5),   Self Y (7)   -&gt; Measured directly &amp; in constraint
    
    H = [0 0 0 0 1 0 0 0;  % Measure Self X (State 5)
         0 0 0 0 0 0 1 0;  % Measure Self Y (State 7)
         sin_b, 0, -cos_b, 0, -sin_b, 0, cos_b, 0]; % Constraint
         
    % Measurement Vector
    z_meas = [x_i; y_i; 0];
    
    % Residual
    y_hat = H * X_est;
    resid = z_meas - y_hat;
    
    % Kalman Gain
    S = H * P * H&apos; + R;
    K = P * H&apos; / S;
    
    % Update State
    X_est = X_est + K * resid;
    
    % Update Covariance
    P = (eye(8) - K * H) * P;
    
    % SAFETY: Force Symmetry (Prevents crashes in long simulations)
    P = 0.5 * (P + P&apos;);

    % --- Output ---
    est_x = X_est(1); % Target X
    est_y = X_est(3); % Target Y (Note: index 3, not 2!)
    
    exec_time = toc(tStart); 
end</P>
      </eml>
    </state>
    <data SSID="6" name="x_i">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="y_i">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="4" name="beta_i">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="est_x">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="est_y">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="10" name="exec_time">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <transition SSID="2">
      <P Name="labelString">{eML_blk_kernel();}</P>
      <P Name="labelPosition">[28.125 13.875 102.544 14.964]</P>
      <P Name="fontSize">12</P>
      <src>
        <P Name="intersection">[0 0 1 0 23.5747 14.625 0 0]</P>
      </src>
      <dst>
        <P Name="SSID">3</P>
        <P Name="intersection">[1 0 -1 0 23.5747 42.5747 0 0]</P>
      </dst>
      <P Name="midPoint">[23.5747 24.9468]</P>
      <P Name="dataLimits">[21.175 25.975 14.625 42.575]</P>
      <P Name="subviewer">129</P>
      <P Name="drawStyle">SMART</P>
      <slide>
        <P Name="sticky">BOTH_STICK</P>
      </slide>
      <P Name="executionOrder">1</P>
    </transition>
    <junction SSID="3">
      <P Name="position">[23.5747 49.5747 7]</P>
      <P Name="subviewer">129</P>
      <P Name="type">CONNECTIVE_JUNCTION</P>
    </junction>
  </Children>
</chart>

