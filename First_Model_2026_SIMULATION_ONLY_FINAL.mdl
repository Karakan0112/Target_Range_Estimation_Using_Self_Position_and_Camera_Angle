<?xml version="1.0" encoding="utf-8"?>
<chart id="39">
  <P Name="name">Observer_Position/Lemniscate_transformation</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">39</P>
  <P Name="visible">1</P>
  <subviewS/>
  <P Name="ssIdHighWaterMark">14</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">3</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">Kinematics_Lemniscate</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">39</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [x_lemniscate, y_lemniscate] = Kinematics_Lemniscate(x_init, y_init, t, w, a)
    % Kinematics_Circular_and_Lemniscate Calculates self position for circular and lemniscate paths.
    % These complex paths ensure the required &apos;excitation&apos; for passive tracking observability.
    %
    % Inputs: 
    %   x_init, y_init: Initial position (meters). Used for center offset and radius/width calculation.
    %   t: Current simulation time (seconds).
    %   w: Angular velocity (rad/s), controls the speed of the motion.
    
    % --- 1. Calculate Radius/Width (R) ---
    % R is determined by the distance from the origin (0,0) to the initial position (x_init, y_init).
    R = sqrt(x_init^2 + y_init^2);
    
    % Safety check: If starting at (0,0), set a minimum radius/width to ensure movement.
    if R == 0
        R = 100; % Default to a 100m scale.
    end

    
    % --- 3. Lemniscate (Figure-8) Motion (Outputs: x_lemniscate, y_lemniscate) ---
    % Lemniscate of Bernoulli equations: x = a*cos(theta)/denom, y = a*sin(theta)*cos(theta)/denom
    % We use R as the width parameter &apos;a&apos; (a_lemniscate).
    
    a_lemniscate = a * sqrt(2); 
    
    theta = w * t;
    denom = 1 + sin(theta)^2;
    
    % Calculate position relative to (0,0)
    x_local = (a_lemniscate * cos(theta)) ./ denom;
    y_local = (a_lemniscate * sin(theta) .* cos(theta)) ./ denom;
    
    % Shift the figure-8 so it is centered near the initial position
    x_lemniscate = x_local + x_init;
    y_lemniscate = y_local + y_init;
</P>
      </eml>
    </state>
    <data SSID="4" name="x_init">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="y_init">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="10" name="t">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="w">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
