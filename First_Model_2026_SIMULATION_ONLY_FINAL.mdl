  <eml>
    <P Name="name">lin_target_pos</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">73</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [x_lin, y_lin] = lin_target_pos(x_i, y_i, v_x, v_y, t)
    % Calculate the linear position in the X direction
    % Formula: x(t) = x_initial + (velocity_x * time)
    x_lin = x_i + (v_x * t);

    % Calculate the linear position in the Y direction
    % Formula: y(t) = y_initial + (velocity_y * time)
    y_lin = y_i + (v_y * t);
</P>
      </eml>
    </state>
    <data SSID="4" name="x_i">
      <P Name="scope">INPUT_DATA</P>
