<?xml version="1.0" encoding="utf-8"?>
<chart id="148">
  <P Name="name">UKF_algorithm/UKF_Static</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">148</P>
  <P Name="ssIdHighWaterMark">10</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">16</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">UKF_Static</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">148</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [est_x, est_y, exec_time] = UKF_Static(x_i, y_i, beta_i)
    % UKF_Static_Final
    % Unscented Kalman Filter for Static Target (6-State).
    % Estimates: [Target_X, Target_Y, Self_X, Self_Vx, Self_Y, Self_Vy]
    
    persistent X_est P Q R 
    
    % --- Timing ---
    exec_time = 0; 
    coder.extrinsic(&apos;tic&apos;, &apos;toc&apos;); 
    tStart = tic; 
    
    % --- Initialization ---
    if isempty(P)
        nx = 6; % State Dimension
        
        % 1. Covariance (P) - High uncertainty
        P = 1000 * eye(nx); 
        
        % 2. Process Noise (Q)

        Q = 0.001 * diag([0.01, 0.01, 100, 10, 100, 10]); 
        
        % 3. Measurement Noise (R)
        % [Self_X, Self_Y, Constraint]
        % UPDATED: Matches your Simulink noise (5) and Constraint (200)
        R = diag([5, 5, 200]); 
    end
    
    if isempty(X_est)
        X_est = zeros(6, 1); 
    end
    
    % --- UKF Parameters (Calculated every step, like student code) ---
    nx = 6;
    alpha = 1e-3; 
    beta_param = 2; 
    kappa = 0; 
    lambda = alpha^2 * (nx + kappa) - nx;
    
    % Weights
    Wm = [lambda / (nx + lambda); repmat(1 / (2 * (nx + lambda)), 2 * nx, 1)];
    Wc = Wm;
    Wc(1) = Wc(1) + (1 - alpha^2 + beta_param);
    
    dt = 0.01; % Sample time
    
    % ===========================================
    % 1. GENERATE SIGMA POINTS
    % ===========================================
    
    % FIX: Diagonal Loading (Replaces try/catch)
    % Ensures P is Positive Definite so chol() never crashes
    P_stable = P + 1e-9 * eye(nx);
    
    S = chol((nx + lambda) * P_stable, &apos;lower&apos;);
    sigma_points = [X_est, bsxfun(@plus, X_est, S), bsxfun(@minus, X_est, S)];
    
    % ===========================================
    % 2. PREDICT STEP (Time Update)
    % ===========================================
    
    % Pass through Static Process Model (Target V=0)
    predicted_sigmas = process_model_static(sigma_points, dt);
    
    % Recover Mean and Covariance
    [X_pred, P_pred] = compute_mean_and_cov(predicted_sigmas, Wm, Wc, Q);
    
    % ===========================================
    % 3. UPDATE STEP (Measurement Update)
    % ===========================================
    
    % Pass through Pseudolinear Measurement Model
    measured_sigmas = measurement_model(predicted_sigmas, beta_i);
    
    % Recover Measurement Mean and Covariance
    [y_pred, Pyy] = compute_mean_and_cov(measured_sigmas, Wm, Wc, R);
    
    % Cross-Covariance
    Pxy = compute_cross_cov(predicted_sigmas, measured_sigmas, X_pred, y_pred, Wc);
    
    % Kalman Gain
    K = Pxy / Pyy;
    
    % Measurement Vector (Observed)
    z_meas = [x_i; y_i; 0]; 
    
    % Update State and Covariance
    resid = z_meas - y_pred;
    X_est = X_pred + K * resid;
    P = P_pred - K * Pyy * K&apos;;
    
    % SAFETY: Force Symmetry
    P = 0.5 * (P + P&apos;);
    
    % --- Outputs ---
    est_x = X_est(1); % Target X
    est_y = X_est(2); % Target Y
    
    exec_time = toc(tStart); 
end

%% --- Helper Functions ---

function points_out = process_model_static(points_in, dt)
    % Static Model: Target Velocity is 0. Self Velocity is constant.
    % 6x6 Matrix
    F = [1 0 0 0 0 0;  % Tx
         0 1 0 0 0 0;  % Ty
         0 0 1 dt 0 0; % Sx
         0 0 0 1 0 0;  % Svx
         0 0 0 0 1 dt; % Sy
         0 0 0 0 0 1]; % Svy
         
    points_out = F * points_in;
end

function points_out = measurement_model(points_in, beta)
    % Pseudolinear Measurement Matrix
    s = sin(beta);
    c = cos(beta);
    
    % H Matrix (3x6)
    % Rows 1-2: Measure Self X (Idx 3) and Self Y (Idx 5)
    % Row 3: Constraint involving Tx(1), Ty(2), Sx(3), Sy(5)
    H = [0 0 1 0 0 0;    % Self X
         0 0 0 0 1 0;    % Self Y
         s, -c, -s, 0, c, 0]; % Constraint
         
    points_out = H * points_in;
end

function [mean_out, cov_out] = compute_mean_and_cov(sigmas, Wm, Wc, NoiseCov)
    % Weighted Mean
    mean_out = sigmas * Wm;
    
    % Weighted Covariance
    d = bsxfun(@minus, sigmas, mean_out);
    cov_out = d * diag(Wc) * d&apos; + NoiseCov;
end

function Pxy = compute_cross_cov(sig_pred, sig_meas, x_mean, y_mean, Wc)
    % Cross Covariance
    dx = bsxfun(@minus, sig_pred, x_mean);
    dy = bsxfun(@minus, sig_meas, y_mean);
    Pxy = dx * diag(Wc) * dy&apos;;
end</P>
      </eml>
    </state>
    <data SSID="6" name="x_i">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
