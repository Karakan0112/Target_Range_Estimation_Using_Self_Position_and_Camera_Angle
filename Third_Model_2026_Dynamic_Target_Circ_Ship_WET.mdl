<?xml version="1.0" encoding="utf-8"?>
<chart id="22">
  <P Name="name">RLS_algorithm/RLS_Static</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">22</P>
  <P Name="visible">1</P>
  <P Name="ssIdHighWaterMark">9</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">4</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">RLS_Static</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">22</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [x_rls, y_rls, exec_time] = RLS_Static(x_observer, y_observer, beta)
    % Inputs:
    %   x_observer, y_observer: Our ship&apos;s current position
    %   beta: Measured angle to target in radians

    persistent P X_est
    

    
    % Performance tracking
    exec_time = 0;
    coder.extrinsic(&apos;tic&apos;, &apos;toc&apos;);
    tStart = tic;

    % Initialization
    if isempty(P)
        P = 10000 * eye(2); % High initial uncertainty
        X_est = [0; 0];     % Initial guess (could be improved if you have a range guess)
    end

    % Pseudolinear Measurement Vector
    % Model: x_target * sin(beta) - y_target * cos(beta) = x_obs * sin(beta) - y_obs * cos(beta)
    
    sin_b = sin(beta);
    cos_b = cos(beta);

    % Measurement Matrix H
    H = [sin_b, -cos_b]; 
    
    % The &quot;Pseudo-measurement&quot; z
    z = x_observer * sin_b - y_observer * cos_b;

    % --- RLS Update ---
    
    % 1. Calculate Gain
    % We use R_cov here instead of &apos;1&apos;
    S = H * P * H&apos; + 1; 
    K = (P * H&apos;) / S;

    % 2. Error (Innovation)
    e = z - H * X_est;

    % 3. Update State
    X_est = X_est + K * e;

    % 4. Update Covariance
    P = (eye(2) - K * H) * P;

    % --- Outputs ---
    x_rls = X_est(1);
    y_rls = X_est(2);
    exec_time = toc(tStart);
end</P>
      </eml>
    </state>
    <data SSID="6" name="x_observer">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="y_observer">
