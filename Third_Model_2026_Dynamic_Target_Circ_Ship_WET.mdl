<?xml version="1.0" encoding="utf-8"?>
<chart id="73">
  <P Name="name">errors_and_display_rls/Calculate_axis_errors</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">73</P>
  <P Name="ssIdHighWaterMark">13</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">10</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">Calculate_axis_errors</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">73</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [pct_err_x, pct_err_y, sleeve_x_up, sleeve_x_down, sleeve_y_up, sleeve_y_down] = Calculate_axis_errors(x_est, y_est, x_tgt, y_tgt)
    % Inputs:
    %   x_est, y_est: Estimated position
    %   x_tgt, y_tgt: Real Target position

    % --- 1. Calculate Percentage Errors (Per Axis) ---
    % Useful for statistics: &quot;What is my % error on X?&quot;
    if abs(x_tgt) &lt; 0.001, x_tgt = 0.001; end
    if abs(y_tgt) &lt; 0.001, y_tgt = 0.001; end
    
    pct_err_x = ((x_est - x_tgt) / x_tgt) * 100;
    pct_err_y = ((y_est - y_tgt) / y_tgt) * 100;

    % --- 2. Calculate Sleeve Bounds (The &quot;Tunnel&quot;) ---
    % Useful for Visualization: Plot &apos;x_est&apos; against these two lines.
    
    % Calculate 10% margin based on absolute position
    margin_x = 0.1 * abs(x_tgt);
    margin_y = 0.1 * abs(y_tgt);
    
    % Define Upper and Lower walls of the tunnel
    sleeve_x_up   = x_tgt + margin_x; % Real X + 10%
    sleeve_x_down = x_tgt - margin_x; % Real X - 10%
    
    sleeve_y_up   = y_tgt + margin_y; % Real Y + 10%
    sleeve_y_down = y_tgt - margin_y; % Real Y - 10%
end</P>
      </eml>
    </state>
    <data SSID="4" name="x_est">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="pct_err_x">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="y_est">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
